{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path aliases — ADR-0002 §3 계층 (ui → core ← data, platform → ui). ui 계층 = src/(Vite 기본, 별도 ui/ 없음) */
    "paths": {
      "@core/*": ["./core/*"],
      "@data/*": ["./data/*"],
      "@ui/*": ["./src/*"],
      "@platform/*": ["./platform/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "core", "data", "platform"]
}
